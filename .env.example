# =============================================================================
# Autico.ai — environment template
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.
# =============================================================================

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://autico.ai

# --- Lead capture -----------------------------------------------------------
# Where /api/lead form submissions get emailed.
LEAD_NOTIFY_EMAIL=john@optinetsolutions.com

# --- Resend (transactional email) -------------------------------------------
# Sign up: https://resend.com  → API Keys
RESEND_API_KEY=

# --- Supabase (optional — leads + products DB) ------------------------------
# Create project: https://supabase.com  → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (image gen — "nano-banana") ------------------------------
# Get key: https://aistudio.google.com/apikey
# Used by tools/generate_product_image.py
GEMINI_API_KEY=

# --- OpenAI (optional — copy generation, embeddings) ------------------------
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Analytics (optional) ---------------------------------------------------
PLAUSIBLE_DOMAIN=autico.ai
